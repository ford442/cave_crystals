# Copy to .env and fill in values locally. Never commit .env or deploy.local.json.
#
#   cp .env.example .env
#   # edit .env, then: set -a && source .env && set +a && python3 deploy.py

# Required for deploy.py (Contabo bundle API)
DEPLOY_TOKEN=

# Optional overrides (defaults shown)
DEPLOY_PROJECT_NAME=cave-crystals
DEPLOY_BUILD_DIR=dist
DEPLOY_CONTABO_BASE_URL=https://storage.noahcohn.com
DEPLOY_FOLDER=

# Optional path to a JSON config file (default: deploy.local.json)
# DEPLOY_CONFIG=deploy.local.json
