{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0
  },
  "include": [
    "src/global.d.ts",
    "src/modules/types.js",
    "src/modules/Game.js",
    "src/modules/GameRuntime.js",
    "src/modules/Renderer.js",
    "src/modules/RendererConstants.js",
    "src/modules/WasmManager.js",
    "src/modules/WasmFallbacks.js",
    "src/modules/WasmConstants.js",
    "src/modules/WasmLogging.js",
    "src/modules/Entities.js",
    "src/modules/renderers/RendererHost.js",
    "src/modules/renderers/CrystalRenderer.js",
    "src/modules/renderers/CaveRenderer.js",
    "src/modules/renderers/PostEffectsRenderer.js",
    "src/modules/renderers/HudEffectsRenderer.js",
    "src/modules/renderers/ParticleRenderer.js"
  ]
}
