{
  "name": "crystal-cave-spore-hunter",
  "version": "1.0.0",
  "description": "A procedural arcade shooter",
  "scripts": {
    "asbuild:debug": "asc src/assembly/index.ts --target debug",
    "asbuild:release": "asc src/assembly/index.ts --target release",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "dev": "npm run asbuild && vite",
    "build": "npm run asbuild && vite build",
    "preview": "vite preview",
    "verify:build": "npm run build",
    "verify:smoke": "python3 verification/verify_juice.py",
    "verify:visual": "python3 verification/run_all.py",
    "verify": "npm run verify:build && npm run verify:smoke",
    "typecheck": "tsc --noEmit",
    "test:wasm": "npm run asbuild:release && node --test test/wasm/*.test.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@assemblyscript/loader": "^0.28.9",
    "acorn": "^8.16.0",
    "assemblyscript": "^0.28.9",
    "typescript": "^5.8.3",
    "vite": "^5.0.0"
  }
}
